# Copy to .env and adjust as needed. All values have sensible defaults.

# Redis connection for the API cache. If unreachable, the API degrades gracefully.
REDIS_URL=redis://localhost:6379/0

# SQLite database path used by the mock Snowflake connector.
MACROSHOCK_DB=data/macroshock.db

# Base URL the Streamlit dashboard uses to reach the Flask API.
API_BASE=http://localhost:5000

# Optional API key. If set, POST/DELETE endpoints require an X-API-Key header (the
# dashboard reads the same var and sends it). Leave unset for an open local demo.
# MACROSHOCK_API_KEY=change-me

# Max POST/DELETE requests per IP per minute (in-process rate limiter).
MACROSHOCK_RATE_PER_MIN=120

# Data source for the seed: synthetic (default) | yahoo | csv.
# Build real-data history: python -m data.seed --source yahoo --start 2012-01-01
# MACROSHOCK_SOURCE=synthetic
